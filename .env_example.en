# ============================================================================
# MediaRaven - Example configuration file
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real `.env` to Git.
# ============================================================================


# ----------------------------------------------------------------------------
# TELEGRAM (required)
# ----------------------------------------------------------------------------

# Your bot token, obtained from @BotFather on Telegram.
# Format: "<numeric_id>:<alphanumeric_token>"
TELEGRAM_BOT_TOKEN="000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

# IDs of chats/groups allowed to use the bot (comma-separated).
# Groups start with "-100..." (supergroups) or "-..." (regular groups).
# How to get: send a message in the group and check https://api.telegram.org/bot<TOKEN>/getUpdates
ALLOWED_CHAT_ID=-1001234567890,-1000987654321

# IDs of allowed users (comma-separated). These users can use the bot in any
# chat, bypassing the ALLOWED_CHAT_ID whitelist.
# How to get your ID: talk to @userinfobot on Telegram.
ALLOWED_USER_IDS=123456789,987654321


# ----------------------------------------------------------------------------
# INSTAGRAM (optional - only required to download from Instagram via Instagrapi)
# ----------------------------------------------------------------------------

# Instagram account credentials used as fallback when yt-dlp fails.
# Recommendation: use a throwaway/secondary account, NOT your main one.
# Leave both blank to disable Instagrapi downloads.
IG_USER=your_username@email.com
IG_PASS=your_instagram_password

# File where the Instagrapi session is persisted (avoids re-login each time).
# Path is relative to the bot directory. Doesn't need to exist — it will be created.
IG_SESSION_FILE=ig_session.json

# How many jobs may queue in Instagrapi before logging a warning.
IG_QUEUE_WARN_THRESHOLD=5


# ----------------------------------------------------------------------------
# LOCAL TELEGRAM BOT API (required)
# ----------------------------------------------------------------------------

# Host:port of the locally-running Telegram Bot API server.
# Required because the bot uses local_mode=True (allows uploads up to 2GB,
# or 4GB if the bot owner is Telegram Premium).
# See https://github.com/tdlib/telegram-bot-api to install the server.
# Examples:
#   LOCAL_API_HOST=127.0.0.1:8081       (same host)
#   LOCAL_API_HOST=192.168.1.100:8081   (another LAN host)
LOCAL_API_HOST=127.0.0.1:8081


# ----------------------------------------------------------------------------
# SYSTEM PATHS (required)
# ----------------------------------------------------------------------------

# Folder where the bot creates "task_*" temporary subfolders for each download.
# MUST be an ABSOLUTE path — the bot rejects relative paths at boot.
# Use a folder with enough disk space — videos can take up GBs.
# Linux:   BASE_DOWNLOAD_DIR=/mnt/storage/mediaraven
# Windows: BASE_DOWNLOAD_DIR=C:/mediaraven/downloads
BASE_DOWNLOAD_DIR=/mnt/storage/mediaraven

# Path to the Firefox profile from which the bot extracts cookies
# (used by yt-dlp to bypass blocks and by the scraper for logged-in sites).
# Leave blank to disable cookie injection.
#
# Linux:
#   FIREFOX_PROFILE_PATH=/home/user/.mozilla/firefox/xxxxxxxx.default-release
#
# Windows (use forward slashes "/" to avoid escape issues):
#   FIREFOX_PROFILE_PATH=C:/Users/user/AppData/Roaming/Mozilla/Firefox/Profiles/xxxxxxxx.default-release
#
# macOS:
#   FIREFOX_PROFILE_PATH=/Users/user/Library/Application Support/Firefox/Profiles/xxxxxxxx.default-release
FIREFOX_PROFILE_PATH=


# ----------------------------------------------------------------------------
# LOGGING (optional)
# ----------------------------------------------------------------------------

# Minimum log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Use DEBUG temporarily to investigate issues — generates a lot of volume.
LOG_LEVEL=INFO

# Maximum size (in bytes) of each log file before rotating.
# Default: 20MB. Increase if you want a longer history in a single file.
LOG_MAX_BYTES=20971520

# How many rotated files to keep (bot.log.1, bot.log.2, ...).
LOG_BACKUP_COUNT=5


# ----------------------------------------------------------------------------
# PLAYWRIGHT (optional — memory autotuning and navigation)
# ----------------------------------------------------------------------------

# Process RSS limit (in MB) that triggers Playwright context refresh.
# When the bot exceeds this value, it creates a fresh context and closes
# the old one to free memory. Default 1500MB.
PW_REFRESH_RSS_MB_THRESHOLD=1500

# How often the bot CHECKS whether to recycle Playwright (minutes).
PW_REFRESH_CHECK_INTERVAL_MIN=15

# Minimum interval between two refreshes (minutes). Avoids thrashing.
PW_REFRESH_MIN_INTERVAL_MIN=30

# After this time, refresh fires even without memory pressure (hours).
PW_REFRESH_MAX_INTERVAL_HOURS=6

# Max Playwright concurrency — how many pages may run in parallel.
# Lower on RAM-constrained machines (1 or 2); raise on big servers.
PW_CONCURRENCY=3

# Headless browser viewport.
PW_VIEWPORT_WIDTH=1920
PW_VIEWPORT_HEIGHT=1080

# User-Agent used by Playwright in all navigations.
# PLAYWRIGHT_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36

# page.goto timeout (ms) in all flows that use Playwright.
PW_GOTO_TIMEOUT_MS=25000


# ----------------------------------------------------------------------------
# USER INTERACTION (buttons and timeouts)
# ----------------------------------------------------------------------------

# Time (seconds) the bot waits for response on interactive buttons.
ASK_DL_TIMEOUT=5.0
ASK_LANG_TIMEOUT=10.0
ASK_CAPTION_TIMEOUT=5.0
ASK_ARTICLE_TIMEOUT=5.0
ASK_SCREENSHOT_TIMEOUT=5.0

# Default behavior when the timeout above fires without response.
# Download: "yes" downloads automatically; "no" ignores.
# Caption: "no" sends without caption; "yes" includes the social media description.
# Article: "yes" sends the article body as caption when detected.
#   More permissive default than Caption because long news text is
#   usually what the user wants to read.
# Screenshot: "yes" sends the screenshot when the user doesn't reply; "no" falls back to fail + retry.
ASK_DL_DEFAULT=yes
ASK_CAPTION_DEFAULT=no
ASK_ARTICLE_DEFAULT=yes
ASK_SCREENSHOT_DEFAULT=yes

# --- Enable/disable prompts per chat and user ---
#
# For each prompt type (download, caption, lang) there are 3 CSV lists:
#   *_OFF_CHATS — chats where the prompt stays OFF
#   *_ON_USERS  — users who ALWAYS see the prompt (overrides OFF_CHATS)
#   *_OFF_USERS — users who NEVER see the prompt (overrides everything)
#
# Precedence: OFF_USERS > ON_USERS > OFF_CHATS > default (on).
# Default (empty lists) = prompt on in every chat/user.
#
# Example: turn off the download prompt in group "-100123", but keep it
# on for admin 555:
#   PROMPT_DOWNLOAD_OFF_CHATS=-100123
#   PROMPT_DOWNLOAD_ON_USERS=555
#
# When the prompt is off:
#   download: downloads automatically (ignores ASK_DL_DEFAULT)
#   caption:  respects ASK_CAPTION_DEFAULT
#   lang:     skips language detection (yt-dlp downloads the default track)

PROMPT_DOWNLOAD_OFF_CHATS=
PROMPT_DOWNLOAD_ON_USERS=
PROMPT_DOWNLOAD_OFF_USERS=

PROMPT_CAPTION_OFF_CHATS=
PROMPT_CAPTION_ON_USERS=
PROMPT_CAPTION_OFF_USERS=

PROMPT_LANG_OFF_CHATS=
PROMPT_LANG_ON_USERS=
PROMPT_LANG_OFF_USERS=

# Maximum number of URLs processed in a single message.
# Protects against paste-bomb messages with dozens of links.
MAX_URLS_PER_MESSAGE=20


# ----------------------------------------------------------------------------
# YT-DLP (quality, timeout, clients)
# ----------------------------------------------------------------------------

# Maximum video height to download. 1920 = 1080p; 1080 = caps at standard HD;
# 720, 480 for limited connections; 4320 for 8K.
YTDLP_MAX_HEIGHT=1920

# yt-dlp socket timeout (seconds). Old value was 300 (5min).
YTDLP_SOCKET_TIMEOUT=90

# YouTube extractor clients (CSV). Order matters — yt-dlp tries in the
# listed order. If YouTube changes, you may need to adjust.
YTDLP_YT_CLIENTS=ios,mweb,web


# ----------------------------------------------------------------------------
# THREAD POOLS (performance)
# ----------------------------------------------------------------------------

# How many simultaneous yt-dlp downloads.
YTDLP_WORKERS=5

# Instagram downloads (instagrapi is single-threaded by nature, leave at 1).
IG_WORKERS=1

# I/O operations (folder cleanup, etc.).
IO_WORKERS=4


# ----------------------------------------------------------------------------
# AIOHTTP (global HTTP session)
# ----------------------------------------------------------------------------

AIOHTTP_TOTAL_TIMEOUT=30
AIOHTTP_CONNECT_TIMEOUT=10
AIOHTTP_READ_TIMEOUT=20

# Maximum simultaneous HTTP connections.
AIOHTTP_CONN_LIMIT=50

# User-Agent used in generic aiohttp requests.
# AIOHTTP_UA_DEFAULT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# User-Agent used specifically for the Reddit JSON API.
# REDDIT_JSON_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:123.0) Gecko/20100101 Firefox/123.0


# ----------------------------------------------------------------------------
# FILE DOWNLOAD (scraper / fallbacks)
# ----------------------------------------------------------------------------

# Per-file timeout (seconds) when downloading via aiohttp.
DOWNLOAD_TIMEOUT_SECONDS=15


# ----------------------------------------------------------------------------
# GENERIC SCRAPER (final cascade fallback)
# ----------------------------------------------------------------------------
# The scraper runs in tiers, going from cheapest to most expensive:
#   1. Fast HTTP path (curl_cffi) → parse OG/JSON-LD/player config from static HTML
#   2. yt-dlp in forced generic mode
#   3. gallery-dl (gallery sites: Pinterest, Imgur, Tumblr, ArtStation, etc.)
#   4. Playwright deep scrape (network sniff + DOM + JSON-LD + iframes)
#   5. yt-dlp generic on each detected embed iframe (YouTube, Vimeo, etc.)
# If nothing finds media, the handler offers the user (via prompt with buttons)
# to take a page screenshot as alternative — controlled by
# SCRAPE_SCREENSHOT_FALLBACK / ASK_SCREENSHOT_TIMEOUT / ASK_SCREENSHOT_DEFAULT.

# How many files to download in parallel inside the scraper (gather + semaphore).
SCRAPE_MAX_PARALLEL_DOWNLOADS=6

# Hard limit of candidate URLs to download — protects against pages with
# thousands of images (Pinterest, infinite-scroll blogs).
SCRAPE_MAX_MEDIA_URLS=60

# How many times the scraper scrolls the page until media count stabilizes.
# For lazy-load sites — stops automatically when nothing new is found.
SCRAPE_SCROLL_MAX_ROUNDS=4

# Pause (ms) between each scroll to let lazy-load fire.
SCRAPE_SCROLL_PAUSE_MS=3000

# Minimum image size (px) accepted by the scraper.
SCRAPE_MIN_IMAGE_SIZE=50

# ffmpeg timeout (seconds) when muxing HLS/DASH into mp4.
SCRAPE_HLS_TIMEOUT_S=180

# Fast-path HTTP timeout (seconds) via curl_cffi.
SCRAPE_FAST_PATH_TIMEOUT_S=12

# When the scraper can't extract any media, offers to take a page screenshot
# as final alternative. The bot asks the user (👍 Yes / 👎 No buttons) with
# configurable timeout (ASK_SCREENSHOT_TIMEOUT) and default-on-timeout
# (ASK_SCREENSHOT_DEFAULT). Set to "no" to disable.
SCRAPE_SCREENSHOT_FALLBACK=yes

# Enable/disable the gallery-dl tier. Useful for Pinterest, Imgur, Tumblr,
# ArtStation, DeviantArt, and dozens of other gallery sites.
SCRAPE_GALLERY_DL_ENABLE=yes

# Per-call gallery-dl timeout (seconds).
SCRAPE_GALLERY_DL_TIMEOUT_S=90

# Soft paywall bypass. When the initial HTML looks blocked, tries:
#   (a) refetch with Googlebot User-Agent (publishers serve the full article
#       to Google for indexing — works on ~70% of major newspapers).
#   (b) archive.ph snapshot if Googlebot is still blocked.
# Doesn't cover hard paywalls (paid Substack, Patreon, real login). Set to
# "no" to disable and respect the original block.
SCRAPE_PAYWALL_BYPASS=yes

# Timeout (seconds) when fetching the archived version via archive.ph.
SCRAPE_ARCHIVE_TIMEOUT_S=15

# Article/news detection: extracts the body text (via trafilatura) and
# delivers it as caption. Goes through the "Description found" prompt
# using ASK_ARTICLE_TIMEOUT / ASK_ARTICLE_DEFAULT (default "yes" on timeout —
# news text is usually what the user wants to read, so sending by default
# makes more sense than discarding).
SCRAPE_ARTICLE_EXTRACT=yes

# Minimum extracted characters to consider the page a real article.
SCRAPE_ARTICLE_MIN_CHARS=300


# ----------------------------------------------------------------------------
# TELEGRAM (upload, media groups)
# ----------------------------------------------------------------------------

# Telegram read/write timeout when uploading large files (seconds).
TELEGRAM_UPLOAD_TIMEOUT=600

# Chunk size when sending multiple media (Telegram limits 10 per group).
MEDIA_GROUP_CHUNK_SIZE=10

# Delay (seconds) between sending groups of 10 media. Controls flood-risk.
MEDIA_GROUP_DELAY=4


# ----------------------------------------------------------------------------
# UI / MESSAGES
# ----------------------------------------------------------------------------

# Interval (seconds) at which the bot rotates the status message during download.
STATUS_CYCLE_INTERVAL=5

# Maximum URL size to appear in logs (the rest is truncated).
SAFE_URL_MAX_LENGTH=200


# ----------------------------------------------------------------------------
# INSTAGRAM (customization)
# ----------------------------------------------------------------------------

# User-Agent used to download audio from Instagram (outside instagrapi).
# If Instagram blocks this version, swap for a newer one.
# IG_USER_AGENT=Instagram 219.0.0.12.117 Android

# Maximum Instagram caption (description) size before truncating with "...".
IG_CAPTION_MAX=1000


# ----------------------------------------------------------------------------
# THREADS (customization)
# ----------------------------------------------------------------------------

# Minimum image size (pixels) from Threads to keep — filters out thumbnails.
THREADS_MIN_IMAGE_SIZE=500


# ----------------------------------------------------------------------------
# INTERNAL CACHE TTL
# ----------------------------------------------------------------------------

# How long a "Retry" button stays valid after the failure (seconds).
TTL_RETRIES_SECONDS=3600

# How long a prompt (download/language/caption) stays valid (seconds).
TTL_FUTURES_SECONDS=300


# ----------------------------------------------------------------------------
# SHUTDOWN / METRICS
# ----------------------------------------------------------------------------

# How long (seconds) to wait for in-flight downloads when shutting down the bot.
SHUTDOWN_TASKS_TIMEOUT=30

# Interval (minutes) between aggregated metrics logs.
METRICS_LOG_INTERVAL_MIN=30


# ----------------------------------------------------------------------------
# FILE EXTENSIONS (rarely needed)
# ----------------------------------------------------------------------------

# Additional extensions the bot should treat as image/video, comma-separated.
# Prefix with dot or not, doesn't matter ("arw" or ".arw").
# Example:
#   IMAGE_EXTS_EXTRA=arw,dng,raf
#   VIDEO_EXTS_EXTRA=mxf,ts,m2ts
IMAGE_EXTS_EXTRA=
VIDEO_EXTS_EXTRA=
