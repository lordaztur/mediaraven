# ============================================================================
# MediaRaven - Arquivo de configuração de exemplo
# Copie este arquivo para `.env` e preencha com seus valores reais.
# NUNCA commite o `.env` real no Git.
# ============================================================================


# ----------------------------------------------------------------------------
# TELEGRAM (obrigatório)
# ----------------------------------------------------------------------------

# Token do seu bot, obtido com @BotFather no Telegram.
# Formato: "<id_numerico>:<token_alfanumerico>"
TELEGRAM_BOT_TOKEN="000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

# IDs dos chats/grupos autorizados a usar o bot (separados por vírgula).
# Grupos começam com "-100..." (supergrupos) ou "-..." (grupos simples).
# Como obter: envie uma mensagem no grupo e consulte https://api.telegram.org/bot<TOKEN>/getUpdates
ALLOWED_CHAT_ID=-1001234567890,-1000987654321

# IDs dos usuários permitidos (separados por vírgula). Esses usuários podem
# usar o bot em qualquer chat, ignorando a whitelist ALLOWED_CHAT_ID.
# Como obter seu ID: fale com @userinfobot no Telegram.
ALLOWED_USER_IDS=123456789,987654321


# ----------------------------------------------------------------------------
# INSTAGRAM (opcional - necessário apenas para baixar do Instagram via Instagrapi)
# ----------------------------------------------------------------------------

# Credenciais da conta do Instagram usada como fallback quando o yt-dlp falha.
# Recomendação: use uma conta descartável/secundária, NÃO sua conta principal.
# Deixe ambas em branco para desabilitar o download via Instagrapi.
IG_USER=seu_usuario@email.com
IG_PASS=sua_senha_do_instagram

# Arquivo onde a sessão do Instagrapi é persistida (evita re-login toda vez).
# Caminho relativo ao diretório do bot. Não precisa existir — será criado.
IG_SESSION_FILE=ig_session.json

# Quantos jobs podem acumular na fila do Instagrapi antes de logar um warning.
IG_QUEUE_WARN_THRESHOLD=5


# ----------------------------------------------------------------------------
# TELEGRAM BOT API LOCAL (obrigatório)
# ----------------------------------------------------------------------------

# Host:porta do servidor Telegram Bot API rodando localmente.
# Necessário porque o bot usa local_mode=True (permite uploads até 2GB).
# Veja https://github.com/tdlib/telegram-bot-api para instalar o servidor.
# Exemplos:
#   LOCAL_API_HOST=127.0.0.1:8081       (mesmo host)
#   LOCAL_API_HOST=192.168.1.100:8081   (outro host na LAN)
LOCAL_API_HOST=127.0.0.1:8081


# ----------------------------------------------------------------------------
# PATHS DO SISTEMA (obrigatório)
# ----------------------------------------------------------------------------

# Pasta onde o bot cria subpastas temporárias "task_*" para cada download.
# DEVE ser um caminho ABSOLUTO — o bot rejeita paths relativos no boot.
# Use uma pasta com espaço em disco suficiente — vídeos podem ocupar GBs.
# Linux:   BASE_DOWNLOAD_DIR=/mnt/storage/mediaraven
# Windows: BASE_DOWNLOAD_DIR=C:/mediaraven/downloads
BASE_DOWNLOAD_DIR=/mnt/storage/mediaraven

# Caminho do perfil do Firefox de onde o bot extrai cookies
# (usado pelo yt-dlp para burlar bloqueios e pelo scraper para sites logados).
# Deixe em branco para desabilitar a injeção de cookies.
#
# Linux:
#   FIREFOX_PROFILE_PATH=/home/usuario/.mozilla/firefox/xxxxxxxx.default-release
#
# Windows (use barras normais "/" para evitar escape issues):
#   FIREFOX_PROFILE_PATH=C:/Users/usuario/AppData/Roaming/Mozilla/Firefox/Profiles/xxxxxxxx.default-release
#
# macOS:
#   FIREFOX_PROFILE_PATH=/Users/usuario/Library/Application Support/Firefox/Profiles/xxxxxxxx.default-release
FIREFOX_PROFILE_PATH=


# ----------------------------------------------------------------------------
# LOGGING (opcional)
# ----------------------------------------------------------------------------

# Nível mínimo dos logs: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Use DEBUG temporariamente para investigar problemas — gera muito volume.
LOG_LEVEL=INFO

# Tamanho máximo (em bytes) de cada arquivo de log antes de rotacionar.
# Default: 20MB. Aumente se quiser mais janela histórica num único arquivo.
LOG_MAX_BYTES=20971520

# Quantos arquivos rotacionados manter (bot.log.1, bot.log.2, ...).
LOG_BACKUP_COUNT=5


# ----------------------------------------------------------------------------
# PLAYWRIGHT (opcional — autotuning de memória e navegação)
# ----------------------------------------------------------------------------

# Limite de RSS do processo (em MB) para disparar o refresh do contexto do
# Playwright. Quando o bot ultrapassa esse valor, cria um contexto novo e
# fecha o antigo para liberar memória. Default 1500MB.
PW_REFRESH_RSS_MB_THRESHOLD=1500

# Frequência com que o bot CHECA se precisa reciclar o Playwright (minutos).
PW_REFRESH_CHECK_INTERVAL_MIN=15

# Intervalo mínimo entre dois refreshes (minutos). Evita thrashing.
PW_REFRESH_MIN_INTERVAL_MIN=30

# Depois desse tempo, o refresh dispara mesmo sem pressão de memória (horas).
PW_REFRESH_MAX_INTERVAL_HOURS=6

# Concorrência máxima no Playwright — quantas páginas podem rodar em paralelo.
# Diminua em máquinas com RAM apertada (1 ou 2); aumente em servidores gordos.
PW_CONCURRENCY=3

# Viewport do navegador headless.
PW_VIEWPORT_WIDTH=1920
PW_VIEWPORT_HEIGHT=1080

# User-Agent usado pelo Playwright em todas as navegações.
# PLAYWRIGHT_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36

# Timeout (ms) do page.goto em todos os fluxos que usam Playwright.
PW_GOTO_TIMEOUT_MS=25000


# ----------------------------------------------------------------------------
# INTERAÇÃO COM O USUÁRIO (botões e timeouts)
# ----------------------------------------------------------------------------

# Tempo (segundos) que o bot espera a resposta aos botões interativos.
ASK_DL_TIMEOUT=5.0
ASK_LANG_TIMEOUT=10.0
ASK_CAPTION_TIMEOUT=5.0

# Comportamento default quando o timeout acima dispara sem resposta.
# Download: "yes" baixa automaticamente; "no" ignora.
# Caption: "no" envia sem legenda; "yes" inclui a descrição.
ASK_DL_DEFAULT=yes
ASK_CAPTION_DEFAULT=no

# --- Ativar/desativar prompts por chat e usuário ---
#
# Para cada tipo de prompt (download, caption, lang) existem 3 listas CSV:
#   *_OFF_CHATS — chats onde o prompt fica DESLIGADO
#   *_ON_USERS  — usuários que SEMPRE veem o prompt (sobrepõe OFF_CHATS)
#   *_OFF_USERS — usuários que NUNCA veem o prompt (sobrepõe tudo)
#
# Precedência: OFF_USERS > ON_USERS > OFF_CHATS > default (ligado).
# Default (listas vazias) = prompt ligado em todos os chats/usuários.
#
# Exemplo: desligar o prompt de download no grupo "-100123", mas manter
# ligado para o admin 555:
#   PROMPT_DOWNLOAD_OFF_CHATS=-100123
#   PROMPT_DOWNLOAD_ON_USERS=555
#
# Quando o prompt está desligado:
#   download: baixa automaticamente (ignora ASK_DL_DEFAULT)
#   caption:  respeita ASK_CAPTION_DEFAULT
#   lang:     pula a detecção de idiomas (yt-dlp baixa a trilha padrão)

PROMPT_DOWNLOAD_OFF_CHATS=
PROMPT_DOWNLOAD_ON_USERS=
PROMPT_DOWNLOAD_OFF_USERS=

PROMPT_CAPTION_OFF_CHATS=
PROMPT_CAPTION_ON_USERS=
PROMPT_CAPTION_OFF_USERS=

PROMPT_LANG_OFF_CHATS=
PROMPT_LANG_ON_USERS=
PROMPT_LANG_OFF_USERS=

# Número máximo de URLs processadas em uma mesma mensagem.
# Protege contra mensagens paste-bomb com dezenas de links.
MAX_URLS_PER_MESSAGE=20


# ----------------------------------------------------------------------------
# YT-DLP (qualidade, timeout, clients)
# ----------------------------------------------------------------------------

# Altura máxima do vídeo a baixar. 1920 = 1080p; 1080 = limita em HD padrão;
# 720, 480 para conexões limitadas; 4320 para 8K.
YTDLP_MAX_HEIGHT=1920

# Timeout de socket do yt-dlp (segundos). Valor antigo era 300 (5min).
YTDLP_SOCKET_TIMEOUT=90

# Clientes do extractor do YouTube (CSV). Ordem importa — o yt-dlp tenta
# na ordem listada. Se o YouTube mudar, pode ser necessário ajustar.
YTDLP_YT_CLIENTS=ios,mweb,web


# ----------------------------------------------------------------------------
# POOLS DE THREADS (performance)
# ----------------------------------------------------------------------------

# Quantos downloads yt-dlp simultâneos.
YTDLP_WORKERS=5

# Downloads do Instagram (instagrapi é single-threaded por natureza, deixe em 1).
IG_WORKERS=1

# Operações de I/O (limpeza de pastas, etc.).
IO_WORKERS=4


# ----------------------------------------------------------------------------
# AIOHTTP (sessão HTTP global)
# ----------------------------------------------------------------------------

AIOHTTP_TOTAL_TIMEOUT=30
AIOHTTP_CONNECT_TIMEOUT=10
AIOHTTP_READ_TIMEOUT=20

# Máximo de conexões HTTP simultâneas.
AIOHTTP_CONN_LIMIT=50

# User-Agent usado em requisições aiohttp genéricas.
# AIOHTTP_UA_DEFAULT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# User-Agent usado especificamente na API JSON do Reddit.
# REDDIT_JSON_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:123.0) Gecko/20100101 Firefox/123.0


# ----------------------------------------------------------------------------
# DOWNLOAD DE ARQUIVOS (scraper / fallbacks)
# ----------------------------------------------------------------------------

# Tamanho mínimo (bytes) para não descartar como placeholder/pixel tracking.
MIN_CONTENT_LENGTH_BYTES=20000

# Timeout individual (segundos) ao baixar um arquivo via aiohttp.
DOWNLOAD_TIMEOUT_SECONDS=15


# ----------------------------------------------------------------------------
# TELEGRAM (upload, grupos de mídia)
# ----------------------------------------------------------------------------

# Timeout de leitura/escrita do Telegram ao subir arquivos grandes (segundos).
TELEGRAM_UPLOAD_TIMEOUT=600

# Tamanho do chunk ao enviar múltiplas mídias (Telegram limita a 10 por grupo).
MEDIA_GROUP_CHUNK_SIZE=10

# Delay (segundos) entre envios de grupos de 10 mídias. Controla flood-risk.
MEDIA_GROUP_DELAY=4


# ----------------------------------------------------------------------------
# INTERFACE / MENSAGENS
# ----------------------------------------------------------------------------

# Intervalo (segundos) com que o bot troca a mensagem de status durante o download.
STATUS_CYCLE_INTERVAL=5

# Tamanho máximo de URL a aparecer nos logs (resto é truncado).
SAFE_URL_MAX_LENGTH=200


# ----------------------------------------------------------------------------
# INSTAGRAM (customização)
# ----------------------------------------------------------------------------

# User-Agent usado ao baixar áudio do Instagram (fora do instagrapi).
# Se o Instagram bloquear essa versão, troque por uma mais recente.
# IG_USER_AGENT=Instagram 219.0.0.12.117 Android

# Tamanho máximo do caption (descrição) do Instagram antes de truncar com "...".
IG_CAPTION_MAX=1000


# ----------------------------------------------------------------------------
# THREADS (customização)
# ----------------------------------------------------------------------------

# Tamanho mínimo (pixels) de imagem do Threads para manter — filtra thumbnails.
THREADS_MIN_IMAGE_SIZE=500

# Palavras-chave na URL que marcam uma imagem como lixo (avatar, ícone, etc).
# THREADS_JUNK_KEYWORDS=s150x150,p150x150,s320x320,p320x320,s480x480,p480x480,profile,avatar,icon,emoji,badge


# ----------------------------------------------------------------------------
# TTL DOS CACHES INTERNOS
# ----------------------------------------------------------------------------

# Quanto tempo um botão "Retry" continua válido após a falha (segundos).
TTL_RETRIES_SECONDS=3600

# Quanto tempo um prompt (download/idioma/caption) continua válido (segundos).
TTL_FUTURES_SECONDS=300


# ----------------------------------------------------------------------------
# SHUTDOWN / MÉTRICAS
# ----------------------------------------------------------------------------

# Quanto tempo (segundos) esperar downloads em andamento ao desligar o bot.
SHUTDOWN_TASKS_TIMEOUT=30

# Intervalo (minutos) entre logs de métricas agregadas.
METRICS_LOG_INTERVAL_MIN=30


# ----------------------------------------------------------------------------
# EXTENSÕES DE ARQUIVO (raramente necessário)
# ----------------------------------------------------------------------------

# Extensões adicionais que o bot deve tratar como imagem/vídeo, separadas por
# vírgula. Prefixe com ponto ou não, tanto faz ("arw" ou ".arw").
# Exemplo:
#   IMAGE_EXTS_EXTRA=arw,dng,raf
#   VIDEO_EXTS_EXTRA=mxf,ts,m2ts
IMAGE_EXTS_EXTRA=
VIDEO_EXTS_EXTRA=
